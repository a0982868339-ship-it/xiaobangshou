.status-header {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
  color: white;
  padding: 24px;
  border-radius: 20px;
  text-align: center;
  margin-bottom: 16px;
}

.status-icon { font-size: 40px; margin-bottom: 4px; }
.status-text { font-size: 22px; font-weight: 800; }
.status-sub { font-size: 13px; opacity: 0.9; }

/* 收入卡片 */
.income-card {
  background: linear-gradient(135deg, #1fa2ff, #12d8fa, #a6ffcb);
  color: #1c3d52;
  padding: 20px;
  border-radius: 20px;
  margin-bottom: 20px;
  text-align: center;
  box-shadow: 0 8px 16px rgba(31, 162, 255, 0.2);
}
