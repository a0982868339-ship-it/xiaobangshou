  transition: all 0.2s;
}
.quick-tag.active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: 700;
}

.popup-footer { padding: 16px 20px; padding-bottom: calc(16px + env(safe-area-inset-bottom)); border-top: 1px solid #f0f0f0; }
.submit-btn { background: #11998e; border: none; font-weight: 800; height: 48px; }
</style>
